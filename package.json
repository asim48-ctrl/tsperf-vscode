{
  "name": "tsperf-vscode",
  "displayName": "TSPerf",
  "description": "Shows TypeScript type inspection latency and symbol complexity signals in VS Code.",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "asim48",
  "repository": {
    "type": "git",
    "url": "https://github.com/asim48-ctrl/tsperf-vscode.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": ["Programming Languages", "Linters"],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onCommand:tsperf.inspectTypeAtCursor",
    "onCommand:tsperf.runFixtureBenchmark"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tsperf.inspectTypeAtCursor",
        "title": "TSPerf: Inspect Type at Cursor"
      },
      {
        "command": "tsperf.runFixtureBenchmark",
        "title": "TSPerf: Run Fixture Benchmark"
      }
    ],
    "configuration": {
      "title": "TSPerf",
      "properties": {
        "tsperf.maxFileSizeKb": {
          "type": "number",
          "default": 512,
          "description": "Maximum TypeScript document size TSPerf will inspect automatically."
        },
        "tsperf.enableInlineDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show inline latency and complexity measurements on inspected lines."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "vsce package"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.1"
  }
}
